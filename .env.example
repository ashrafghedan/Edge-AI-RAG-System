# ---------------------------------------------------------------------------
# Edge AI RAG — environment configuration
# Copy this file to ".env" and adjust the values for your machine.
# ---------------------------------------------------------------------------

# PostgreSQL connection (SQLAlchemy + psycopg v3 driver).
# Format: postgresql+psycopg://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/edge_rag

# ---------------------------------------------------------------------------
# Local llama.cpp server (OpenAI-compatible /v1/* API). `npm run dev` probes
# LLAMA_CPP_BASE_URL and, if nothing is listening, starts llama-server itself.
# ---------------------------------------------------------------------------
LLAMA_CPP_BASE_URL=http://127.0.0.1:11436
LLAMA_CPP_MODEL=gemma-4-e2b-q4km

# Absolute path to the llama-server binary and the GGUF model on this machine.
# Windows example shown; on Linux use the matching paths.
LLAMA_SERVER_BIN=C:/path/to/llama.cpp/llama-server.exe
LLAMA_CPP_MODEL_PATH=C:/path/to/models/gemma-3n-E2B-it-Q4_K_M.gguf

# Vision (image input) requires a multimodal projector (mmproj) GGUF.
# Leave disabled when running a text-only model.
LLAMA_CPP_VISION_ENABLED=0
# LLAMA_CPP_MMPROJ_PATH=C:/path/to/models/mmproj-F16.gguf

# Reasoning / thinking tokens: auto | on | off
LLAMA_CPP_REASONING=on

# Generation / context budget (lower these on smaller GPUs).
LLAMA_CPP_NUM_CTX=6144
LLAMA_CPP_MAX_TOKENS=3072
LLAMA_CPP_NGL=99
LLAMA_CPP_EMBEDDINGS=1

# RAG behaviour
EDGE_RAG_ANSWER_TEMPERATURE=0.0
EDGE_RAG_TOP_K=4

# Offline speech-to-text (faster-whisper, runs locally on CPU).
EDGE_RAG_STT_BACKEND=faster_whisper
EDGE_RAG_STT_MODEL=data/models/faster-whisper-tiny
EDGE_RAG_STT_DEVICE=cpu
EDGE_RAG_STT_COMPUTE_TYPE=int8

# Frontend dev origin allowed by CORS.
FRONTEND_ORIGINS=http://localhost:5173
